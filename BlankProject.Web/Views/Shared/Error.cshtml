@model ErrorViewModel
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="text-center mt-5">
    @switch (Model.StatusCode)
    {
        case 404:
            <div style="font-size: 6rem;">🔍</div>
            break;
        case 403:
            <div style="font-size: 6rem;">🔒</div>
            break;
        default:
            <div style="font-size: 6rem;">⚠️</div>
            break;
    }

    <h1 class="display-4 text-@(Model.StatusCode == 404 ? "warning" : "danger") mt-3">@Model.StatusCode</h1>
    <h2 class="mb-3">@Model.Titulo</h2>
    <p class="lead text-muted">@Model.Mensaje</p>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            Volver al inicio
        </a>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="mt-4">
            <small class="text-muted">Request ID: <code>@Model.RequestId</code></small>
        </div>
    }
</div>

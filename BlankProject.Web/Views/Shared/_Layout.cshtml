<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlankProject</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#2b9de4" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="BlankProject" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/olvidata-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BlankProject.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
</head>
<body>
    <!-- --- TOPBAR --- -->
    <header class="ov-topbar">
        <button class="ov-topbar-toggle" id="sidebarToggle" aria-label="Menu">
            <i class="fas fa-bars"></i>
        </button>

        <a class="ov-topbar-brand" asp-controller="Home" asp-action="Index">
            <span>Olvidata<span class="brand-dot">Soft</span></span>
        </a>

        <span class="ov-env-badge d-none d-md-inline">BlankProject</span>

        <div class="ov-topbar-spacer"></div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Notificaciones -->
            <div class="dropdown">
                <a class="ov-topbar-icon-btn" href="#" data-bs-toggle="dropdown" aria-expanded="false" id="notifBell">
                    <i class="fas fa-bell"></i>
                    <span class="ov-topbar-icon-badge d-none" id="notifBadge">0</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end p-0 ov-notif-dropdown">
                    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                        <strong class="small">Notificaciones</strong>
                        <a href="#" class="small text-decoration-none" id="markAllRead">Marcar todas leídas</a>
                    </div>
                    <div id="notifList"><p class="text-center text-muted small py-3">Cargando...</p></div>
                    <div class="text-center border-top py-2">
                        <a asp-controller="Notifications" asp-action="Index" class="small text-decoration-none">Ver todas</a>
                    </div>
                </div>
            </div>

            <div class="dropdown">
                <a class="ov-topbar-user" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="ov-topbar-avatar">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper())
                    </span>
                    <div class="d-none d-md-flex flex-column lh-1" style="gap:2px;">
                        <span class="ov-text-sm ov-fw-600">@User.Identity.Name</span>
                    </div>
                    <i class="fas fa-chevron-down ov-text-xs ov-text-muted ms-1"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end ov-user-dropdown">
                    <li><span class="dropdown-item-text ov-text-xs ov-text-muted">Sesión activa</span></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Perfil"><i class="fas fa-user fa-fw me-2 ov-text-muted"></i>Mi perfil</a></li>
                    <li><a class="dropdown-item" asp-controller="Account" asp-action="CambiarPassword"><i class="fas fa-key fa-fw me-2 ov-text-muted"></i>Cambiar contraseña</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt fa-fw me-2"></i>Cerrar sesión</button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a class="btn btn-sm btn-ov-primary" asp-controller="Account" asp-action="Login">
                <i class="fas fa-sign-in-alt"></i> Iniciar sesión
            </a>
        }
    </header>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- --- SIDEBAR --- -->
        <nav class="ov-sidebar" id="sidebar">
            <div class="ov-sidebar-nav">
                <div class="ov-sidebar-section">Principal</div>
                <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <span class="sidebar-icon"><i class="fas fa-house"></i></span>
                    <span>Inicio</span>
                </a>
                <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sample" ? "active" : "")"
                   asp-controller="Sample" asp-action="Ping">
                    <span class="sidebar-icon"><i class="fas fa-satellite-dish"></i></span>
                    <span>Sample Ping</span>
                </a>

                <div class="ov-sidebar-section">Administración</div>
                <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")"
                   asp-controller="Audit" asp-action="Index">
                    <span class="sidebar-icon"><i class="fas fa-clock-rotate-left"></i></span>
                    <span>Auditoría</span>
                </a>
                <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notifications" ? "active" : "")"
                   asp-controller="Notifications" asp-action="Index">
                    <span class="sidebar-icon"><i class="fas fa-bell"></i></span>
                    <span>Notificaciones</span>
                </a>
                @if (User.IsInRole("SuperUsuario"))
                {
                    <div class="ov-sidebar-section">Super Usuario</div>
                    <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                       asp-controller="Users" asp-action="Index">
                        <span class="sidebar-icon"><i class="fas fa-users-gear"></i></span>
                        <span>Usuarios</span>
                    </a>
                    <a class="ov-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "System" ? "active" : "")"
                       asp-controller="System" asp-action="Index">
                        <span class="sidebar-icon"><i class="fas fa-toolbox"></i></span>
                        <span>Sistema</span>
                    </a>
                }
            </div>

            <!-- Sidebar bottom branding -->
            <div class="ov-sidebar-bottom">
                <div class="ov-sidebar-brand-mark">
                    <img src="~/icons/icon-192.png" alt="Olvidata" class="ov-brand-icon-img" />
                    <div>
                        <div class="ov-brand-name">Olvidata Soft</div>
                        <div class="ov-brand-sub">Software a medida</div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- --- BACKDROP (mobile) --- -->
        <div class="ov-backdrop" id="sidebarBackdrop"></div>
    }

    <!-- --- MAIN CONTENT --- -->
    <div class="@(User.Identity?.IsAuthenticated == true ? "ov-main" : "container py-5")">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ═══ FOOTER ═══ -->
    <footer class="ov-footer">
        <div class="ov-footer-inner">
            <p class="ov-footer-copy">© @DateTime.Now.Year Olvidata Soft — Todos los derechos reservados.</p>
            <div class="ov-footer-links">
                <a href="https://wa.me/5492214402340" target="_blank" rel="noopener" title="WhatsApp">
                    <i class="fab fa-whatsapp"></i>
                </a>
                <a href="https://www.instagram.com/olvidata.soft/" target="_blank" rel="noopener" title="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="https://olvidata.com.ar/" target="_blank" rel="noopener" title="Sitio web">
                    <i class="fas fa-globe"></i>
                </a>
                <a href="mailto:olvidatasoft@gmail.com?Subject=Consulta%20Desarrollo%20Web" title="Email">
                    <i class="fas fa-envelope"></i>
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        // Registrar Service Worker (PWA)
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(function () { });
        }
    </script>
    <script>
        // Sidebar toggle (mobile)
        (function () {
            var toggle = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('sidebar');
            var backdrop = document.getElementById('sidebarBackdrop');
            if (!toggle || !sidebar) return;
            function closeSidebar() {
                sidebar.classList.remove('open');
                if (backdrop) backdrop.classList.remove('show');
            }
            toggle.addEventListener('click', function () {
                sidebar.classList.toggle('open');
                if (backdrop) backdrop.classList.toggle('show');
            });
            if (backdrop) backdrop.addEventListener('click', closeSidebar);
        })();
    </script>
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Exito',
                text: '@Html.Raw(TempData["SuccessMessage"]?.ToString()?.Replace("'", "\\'"))',
                confirmButtonColor: '#2b9de4'
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@Html.Raw(TempData["ErrorMessage"]?.ToString()?.Replace("'", "\\'"))',
                confirmButtonColor: '#ef4444'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

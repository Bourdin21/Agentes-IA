@model BlankProject.Web.Models.UserDetailsViewModel
@using BlankProject.Domain.Enums
@{
    ViewData["Title"] = "Detalle de Usuario";
}

<h3 class="mb-4">Detalle de Usuario</h3>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>@Model.FullName</strong></div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><th style="width:160px;">Nombre</th><td>@Model.FullName</td></tr>
                    <tr><th>Email</th><td>@Model.Email</td></tr>
                    <tr><th>Rol</th><td><span class="badge bg-primary">@Model.Rol</span></td></tr>
                    <tr>
                        <th>Estado</th>
                        <td>
                            @if (Model.Estado == EstadoUsuario.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Bloqueado</span>
                            }
                        </td>
                    </tr>
                    <tr><th>Creado</th><td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr>
                        <th>Actualizado</th>
                        <td>
                            @if (Model.UpdatedAt.HasValue)
                            {
                                @Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit me-1"></i> Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
        </div>
    </div>
</div>

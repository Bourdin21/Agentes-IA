@model BlankProject.Web.Models.UserListViewModel
@using BlankProject.Domain.Enums
@{
    ViewData["Title"] = "Administrar Usuarios";
    var roles = ViewBag.AvailableRoles as List<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Usuarios</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Nuevo usuario
    </a>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label form-label-sm">Buscar</label>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Nombre o email..." />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">Rol</label>
                <select name="rol" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r" selected="@(Model.RolFilter == r)">@r</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label form-label-sm">Estado</label>
                <select name="estado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="Activo" selected="@(Model.StatusFilter == "Activo")">Activo</option>
                    <option value="Bloqueado" selected="@(Model.StatusFilter == "Bloqueado")">Bloqueado</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i> Filtrar</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-times me-1"></i> Limpiar</a>
            </div>
        </form>
    </div>
</div>

<!-- Tabla -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Creado</th>
                    <th style="width: 180px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No se encontraron usuarios.</td>
                    </tr>
                }
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-primary">@user.Rol</span></td>
                        <td>
                            @if (user.Estado == EstadoUsuario.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Bloqueado</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-info" title="Ver">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="ToggleEstado" asp-route-id="@user.Id" method="post" class="d-inline">
                                    @if (user.Estado == EstadoUsuario.Activo)
                                    {
                                        <button type="submit" class="btn btn-outline-warning btn-swal-confirm" data-message="Se bloqueara el usuario '@user.FullName'. No podra iniciar sesion." title="Bloquear">
                                            <i class="fas fa-user-slash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-outline-success btn-swal-confirm" data-message="Se desbloqueara el usuario '@user.FullName'." title="Desbloquear">
                                            <i class="fas fa-user-check"></i>
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginacion -->
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Mostrando @((Model.Page - 1) * Model.PageSize + 1)-@Math.Min(Model.Page * Model.PageSize, Model.TotalCount) de @Model.TotalCount</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-rol="@Model.RolFilter"
                               asp-route-estado="@Model.StatusFilter"
                               asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

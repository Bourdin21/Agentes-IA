@model BlankProject.Web.Models.PerfilViewModel
@using BlankProject.Domain.Enums
@{
    ViewData["Title"] = "Mi Perfil";
}

<h3 class="mb-4">Mi Perfil</h3>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Datos de la cuenta</strong></div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><th style="width:160px;">Nombre</th><td>@Model.NombreCompleto</td></tr>
                    <tr><th>Email</th><td>@Model.Email</td></tr>
                    <tr><th>Rol</th><td><span class="badge bg-primary">@Model.Rol</span></td></tr>
                    <tr>
                        <th>Estado</th>
                        <td>
                            @if (Model.Estado == EstadoUsuario.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Bloqueado</span>
                            }
                        </td>
                    </tr>
                    <tr><th>Cuenta creada</th><td>@Model.CreadoEl.ToString("dd/MM/yyyy HH:mm")</td></tr>
                </table>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="CambiarPassword" class="btn btn-outline-primary"><i class="fas fa-key me-1"></i> Cambiar contrasena</a>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Inicio";
}

@if (User.Identity?.IsAuthenticated != true)
{
    <div class="text-center mt-5">
        <h1 class="display-4">Bienvenido a BlankProject</h1>
        <p class="lead">Plantilla base para nuevos proyectos. Incluye autenticación, auditoría, notificaciones y más.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg mt-3">Iniciar sesion</a>
    </div>
}
else
{
    <h3 class="mb-4">Bienvenido, @User.Identity.Name</h3>

    <p class="text-muted mb-4">Selecciona una opcion del menu lateral para comenzar.</p>

    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="Account" asp-action="Perfil" class="text-decoration-none">
                <div class="card h-100 text-center border-primary">
                    <div class="card-body py-4">
                        <i class="fas fa-user fa-3x text-primary mb-3"></i>
                        <h5 class="text-primary">Mi Perfil</h5>
                        <p class="text-muted small mb-0">Ver datos de tu cuenta y cambiar contrasena.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Sample" asp-action="Ping" class="text-decoration-none">
                <div class="card h-100 text-center border-info">
                    <div class="card-body py-4">
                        <i class="fas fa-satellite-dish fa-3x text-info mb-3"></i>
                        <h5 class="text-info">Sample Ping</h5>
                        <p class="text-muted small mb-0">Endpoint de ejemplo para validar que la plantilla funciona.</p>
                    </div>
                </div>
            </a>
        </div>
        @if (User.IsInRole("SuperUsuario"))
        {
            <div class="col-md-4">
                <a asp-controller="Users" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center border-success">
                        <div class="card-body py-4">
                            <i class="fas fa-users-gear fa-3x text-success mb-3"></i>
                            <h5 class="text-success">Administrar Usuarios</h5>
                            <p class="text-muted small mb-0">Crear, editar y gestionar cuentas de usuario.</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

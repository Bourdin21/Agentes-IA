@model List<BlankProject.Application.DTOs.NotificationDto>
@{
    ViewData["Title"] = "Notificaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Notificaciones</h3>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-controller="Notifications" asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="fas fa-check-double me-1"></i> Marcar todas leidas</button>
        </form>
    }
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-bell-slash fa-3x mb-3"></i>
            <p>No tiene notificaciones.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="list-group list-group-flush">
            @foreach (var notif in Model)
            {
                <div class="list-group-item @(!notif.IsRead ? "list-group-item-primary" : "")">
                    <div class="d-flex align-items-start">
                        <i class="@notif.Icon me-3 mt-1 text-primary"></i>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <strong class="small">@notif.Title</strong>
                                <small class="text-muted">@notif.TimeAgo</small>
                            </div>
                            <p class="mb-1 small">@notif.Message</p>
                            @if (!string.IsNullOrEmpty(notif.Url))
                            {
                                <a href="@notif.Url" class="small">Ver detalle →</a>
                            }
                        </div>
                        @if (!notif.IsRead)
                        {
                            <form asp-controller="Notifications" asp-action="MarkAsRead" asp-route-id="@notif.Id" method="post" class="ms-2">
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Marcar leida"><i class="fas fa-check"></i></button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

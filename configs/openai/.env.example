# Variables de entorno para integración con OpenAI
# Copiar este archivo a .env y completar con los valores reales
# NUNCA subir el archivo .env al repositorio

OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# Modelo a utilizar (por defecto: gpt-4o)
OPENAI_MODEL=gpt-4o

# Límite de tokens por respuesta
OPENAI_MAX_TOKENS=2048

# Patrones de .gitignore recomendados para proyectos con IA

# Variables de entorno con claves de API
.env
.env.local
.env.*.local

# Caché de modelos de IA locales
*.gguf
*.bin
models/

# Logs de interacciones con agentes de IA
ai-logs/
*.ai.log

# Archivos temporales generados por agentes
.copilot-cache/
.openai-cache/
